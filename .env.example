# =============================================================================
# Server / Docker (copy to `.env` on the VM — never commit `.env`)
# =============================================================================

# Postgres (db service + DATABASE_URL for web are derived from these in docker-compose.yml).
# If you already initialized the DB volume with a different password, changing this line alone
# does not update Postgres — alter the role in psql or recreate the volume.
POSTGRES_USER=music
# Use a long random value. Avoid `:`, `@`, `/`, `%`, `#`, and raw `$` (Compose + URL parsing).
POSTGRES_PASSWORD=replace-with-long-random-secret
POSTGRES_DB=music

DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Optional: reset fan-gate session for a song (testing). Visit:
#   /s/<slug>/?reset_gate=<this exact value>
# When DJANGO_DEBUG=1 you can also use ?reset_gate=1
SMARTLINKS_RESET_GATE_SECRET=

# Off-site backups (scripts/run_scheduled_backups.sh)
BACKUP_DIR=/var/backups/music-marketing
# After `rclone config`, set remote + path, e.g. b2:my-bucket/music-marketing or s3:my-bucket/prefix
RCLONE_REMOTE=

# =============================================================================
# Local Django without Docker (uncomment; do not use sqlite DATABASE_URL on the server)
# =============================================================================
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DATABASE_URL=sqlite:///db.sqlite3
